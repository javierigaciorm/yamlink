{
  "name": "yamlink",
  "displayName": "Yamlink",
  "description": "Turn Markdown into a structured knowledge system. Canonical IDs, vault-wide linking, backlinks, and real-time diagnostics for YAML-based knowledge graphs.",
  "version": "0.1.1",
  "publisher": "yamlink",
  "author": {
    "name": "Javier Ramirez"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/javierigaciorm/yamlink"
  },
  "bugs": {
    "url": "https://github.com/javierigaciorm/yamlink/issues"
  },
  "homepage": "https://github.com/javierigaciorm/yamlink#readme",
  "keywords": [
    "markdown",
    "notes",
    "knowledge-base",
    "knowledge-graph",
    "wikilinks",
    "zettelkasten",
    "pkm",
    "crm",
    "frontmatter",
    "yaml",
    "obsidian",
    "logseq",
    "developer-tools",
    "data-modeling",
    "graph"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:markdown",
    "onView:yamlink.backlinks"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yamlink.createNote",
        "title": "Yamlink: Create Node"
      },
      {
        "command": "yamlink.addFrontmatter",
        "title": "Yamlink: Add Frontmatter"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "yamlink.backlinks",
          "name": "Yamlink Backlinks"
        }
      ]
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}